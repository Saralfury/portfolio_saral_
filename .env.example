# ── Backend API URLs (server-side only — set these in Vercel Dashboard) ────────
# These are used by Next.js API proxy routes, NOT exposed to the browser.
# For local dev, the defaults below (localhost) are used automatically.

# Deploy the 3 FastAPI backends to Render:
#   render.com → New Blueprint → connect portfolio_saral_ repo → render.yaml auto-creates 3 services

# Project 1: Real-Time Fraud & Risk Engine
RISK_ENGINE_URL=https://risk-engine.onrender.com

# Project 2: Smart-Budget Semantic Router
ROUTER_URL=https://semantic-router.onrender.com

# Project 3: AI Health Monitor
HEALTH_MONITOR_URL=https://ai-health-monitor.onrender.com
